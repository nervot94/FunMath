<Window x:Class="FunMath.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notification"
        Width="380"
        Height="230"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#dce0e8">

    <Grid Margin="24">
        <Border Background="#eff1f5"
                CornerRadius="20"
                Padding="24"
                Visibility="Visible">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Game Over"
                               FontSize="28"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="#8839EF"/>

                    <TextBlock x:Name="MessageTextBlock"
                               Margin="0,5,0,0"
                               FontSize="18"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="#4c4f69"
                               Text="Game over! :("/>

                    <TextBlock Text="Druk op OK om verder te gaan."
                               Margin="0,12,0,0"
                               FontSize="14"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="#4c4f69"/>
                </StackPanel>

                <Button Grid.Row="1"
                        Width="120"
                        Height="40"
                        Margin="0,20,0,0"
                        HorizontalAlignment="Center"
                        Background="#209fb5"
                        Foreground="White"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        BorderThickness="0"
                        Content="OK"
                        Click="OkButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8"
                                                BorderThickness="0">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
